{
  "name": "catch-the-wind",
  "version": "1.0.0",
  "description": "Electron application for network traffic monitoring with a Python backend.",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.2.6",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.example.catchthewind",
    "productName": "CatchTheWind",
    "files": [
      "dist/**/*",
      "electron/main.js",
      "electron/preload.js",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "backend-python-dist",
        "to": "core_engine"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    }
  }
}